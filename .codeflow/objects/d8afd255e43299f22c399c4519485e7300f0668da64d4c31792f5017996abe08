    static async Task Main(string[] args)
    {
        Console.WriteLine("CodeFlow CLI");

        if (args.Length == 0)
        {
            PrintHelp();
            return;
        }

        switch (args[0])
        {
            case "init":
                HandleInit();
                break;
            case "keygen":
                HandleKeyGen();
                break;
            case "add":
                HandleAdd(args.Skip(1).ToArray());
                break;
            case "commit":
                HandleCommit(args.Skip(1).ToArray());
                break;
            case "checkout":
                HandleCheckout(args.Skip(1).ToArray());
                break;
            case "log":
                HandleLog();
                break;
            case "verify":
                if (args.Length < 2) { Console.WriteLine("Usage: codeflow verify <commit-hash>"); return; }
                HandleVerify(args[1]);
                break;
            case "remote":
                HandleRemote(args.Skip(1).ToArray());
                break;
            case "push":
                if (args.Length < 2) { Console.WriteLine("Usage: codeflow push <remote>"); return; }
                await HandlePush(args[1]);
                break;
            case "pull":
                if (args.Length < 2) { Console.WriteLine("Usage: codeflow pull <remote>"); return; }
                HandlePull(args[1]);
                break;

            case "audit":
                HandleAudit();
                break;
            case "graph":
                HandleGraph();
                break;
            case "serve":
                await HandleServe();
                break;
            case "status":
                HandleStatus();
                break;



            default:
                PrintHelp();
                break;
        }
    }

    /// <summary>
    /// Determines if the given byte array likely contains binary data
    /// that shouldn't be parsed as UTF-8 text/JSON.
    /// </summary>
    /// 
    /// 
    static void HandleStatus()
    {
        Console.WriteLine("🔎 CodeFlow Status\n");

        var repoRoot = Directory.GetCurrentDirectory();
        var store = new ContentAddressableStore(".codeflow/objects");
        var idx = new CodeFlow.Storage.Index(repoRoot);
        var staged = idx.Load(); // Dictionary<string, string>

        var head = store.ReadHead();

        Console.ForegroundColor = ConsoleColor.Cyan;
        Console.WriteLine("On branch main\n"); // If you later add branches, replace this
        Console.ResetColor();

        // === Staged Files ===
        if (staged.Count > 0)
        {
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine("Changes to be committed:\n");
            Console.ResetColor();

            foreach (var file in staged.Keys)
            {
                Console.WriteLine($"  new file:   {file}");
            }

            Console.WriteLine();
        }

        // === Compare working directory with last commit ===
        var trackedFiles = new HashSet<string>();

        if (!string.IsNullOrEmpty(head))
        {
            var raw = store.GetObject(head);
            if (raw != null)
            {
                var commit = Commit.FromJson(raw);
                var treeStore = new TreeStore(new BlobStore(".codeflow/objects"));
                var tree = treeStore.LoadTree(commit.TreeHash);

                foreach (var entry in tree.Entries)
                {
                    trackedFiles.Add(entry.Path);
                }
            }
        }

        var ignore = FlowIgnore.Load(repoRoot);

        var codeflowDir = Path.GetFullPath(Path.Combine(repoRoot, ".codeflow"));

        var workingFiles = Directory
            .EnumerateFiles(repoRoot, "*", SearchOption.AllDirectories)
            .Where(f =>
            {
                var full = Path.GetFullPath(f);

                // Skip .codeflow internals
                if (full.StartsWith(codeflowDir + Path.DirectorySeparatorChar))
                    return false;

                var rel = Path.GetRelativePath(repoRoot, full).Replace('\\', '/');

                // Apply ignore rules
                if (ignore.IsIgnored(rel))
                    return false;

                return true;
            })
            .Select(f => Path.GetRelativePath(repoRoot, f).Replace('\\', '/'))
            .ToList();


        var untracked = workingFiles
            .Where(f => !trackedFiles.Contains(f) && !staged.ContainsKey(f))
            .ToList();

        var modified = new List<string>();

        foreach (var file in trackedFiles)
        {
            var fullPath = Path.Combine(repoRoot, file);

            if (!File.Exists(fullPath))
                continue;

            var bytes = File.ReadAllBytes(fullPath);
            var blobStore = new BlobStore(".codeflow/objects");
            var newHash = blobStore.SaveBlob(bytes);

            var raw = store.GetObject(head);
            var commit = Commit.FromJson(raw);
            var treeStore = new TreeStore(blobStore);
            var tree = treeStore.LoadTree(commit.TreeHash);

            var entry = tree.Entries.FirstOrDefault(e => e.Path == file);
            if (entry != null && entry.Hash != newHash)
            {
                modified.Add(file);
            }
        }

        if (modified.Count > 0)
        {
            Console.ForegroundColor = ConsoleColor.Yellow;
            Console.WriteLine("Modified files:\n");
            Console.ResetColor();

            foreach (var file in modified)
            {
                Console.WriteLine($"  modified:   {file}");
            }

            Console.WriteLine();
        }

        if (untracked.Count > 0)
        {
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine("Untracked files:\n");
            Console.ResetColor();

            foreach (var file in untracked)
            {
                Console.WriteLine($"  {file}");
            }

            Console.WriteLine();
        }

        if (staged.Count == 0 && modified.Count == 0 && untracked.Count == 0)
        {
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine("Working tree clean.");
            Console.ResetColor();
        }
    }

    static async Task HandleServe()
