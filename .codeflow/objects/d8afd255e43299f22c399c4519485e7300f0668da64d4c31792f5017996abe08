    static void HandleGraph()
    {
        Console.WriteLine("CodeFlow Commit Graph\n");

        var store = new ContentAddressableStore(".codeflow/objects");
        var head = store.ReadHead();

        if (string.IsNullOrEmpty(head))
        {
            Console.WriteLine("No commits yet.");
            return;
        }

        var current = head;
        int depth = 0;

        while (!string.IsNullOrEmpty(current))
        {
            var raw = store.GetObject(current);
            if (raw == null)
            {
                Console.WriteLine($"❌ Missing commit: {current}");
                break;
            }

            var commit = Commit.FromJson(raw);

            // Green star
            Console.ForegroundColor = ConsoleColor.Green;
            Console.Write("* ");
            Console.ResetColor();

            if (depth == 0)
            {
                Console.ForegroundColor = ConsoleColor.Yellow;
                Console.Write($"{current.Substring(0, 8)} (HEAD)");
                Console.ResetColor();
            }
            else
            {
                Console.Write(current.Substring(0, 8));
            }

            Console.WriteLine();

            if (!string.IsNullOrEmpty(commit.ParentHash))
            {
                Console.WriteLine("|");
            }

            current = commit.ParentHash;
            depth++;
        }

        Console.WriteLine("\nGraph traversal complete.");
    }

    static void HandleAudit()
    {
        Console.WriteLine("Running CodeFlow Integrity Audit...\n");

        var store = new ContentAddressableStore(".codeflow/objects");
        var head = store.ReadHead();

        if (string.IsNullOrEmpty(head))
        {
            Console.WriteLine("No HEAD found. Repository is empty or corrupted.");
            return;
        }

        Console.WriteLine($"HEAD: {head}\n");

        var reachable = GetObjectHistorySet(head, store);

        int commitCount = 0;
        int treeCount = 0;
        int blobCount = 0;
        int chunkCount = 0;
        int invalidSignatures = 0;
        int missingObjects = 0;

        foreach (var hash in reachable)
        {
            var raw = store.GetRawObject(hash);

            if (raw == null)
            {
                Console.WriteLine($"❌ Missing object: {hash}");
                missingObjects++;
                continue;
            }

            if (IsBinaryData(raw))
            {
                blobCount++;
                continue;
            }

            string text;
            try
            {
                text = Encoding.UTF8.GetString(raw);
            }
            catch
            {
                blobCount++;
                continue;
            }

            bool parsed = false;

            // 1️⃣ Try Commit
            try
            {
                var commit = Commit.FromJson(text);

                // Extra safety: ensure it really looks like a commit
                if (!string.IsNullOrEmpty(commit.TreeHash))
                {
                    commitCount++;

                    if (!commit.VerifySignature())
                    {
                        Console.WriteLine($"❌ Invalid signature: {hash}");
                        invalidSignatures++;
                    }

                    parsed = true;
                }
            }
            catch { }

            if (parsed) continue;

            // 2️⃣ Try Tree
            try
            {
                var tree = Tree.FromJson(text);

                if (tree?.Entries != null)
                {
                    treeCount++;

                    foreach (var entry in tree.Entries)
                    {
                        if (!store.HasObject(entry.Hash))
                        {
                            Console.WriteLine($"❌ Tree {hash} references missing object {entry.Hash}");
                            missingObjects++;
                        }
                    }

                    parsed = true;
                }
            }
            catch { }

            if (parsed) continue;

            // 3️⃣ Try LargeFilePointer
            try
            {
                var ptr = LargeFilePointer.FromJson(text);

                if (ptr?.ChunkHashes != null)
                {
                    chunkCount += ptr.ChunkHashes.Count;

                    foreach (var chunk in ptr.ChunkHashes)
                    {
                        if (!store.HasObject(chunk))
                        {
                            Console.WriteLine($"❌ Missing chunk: {chunk}");
                            missingObjects++;
                        }
                    }

                    parsed = true;
                }
            }
            catch { }

            if (parsed) continue;

            // 4️⃣ Otherwise it's a normal blob
            blobCount++;
        }

        Console.WriteLine("\n-------------------- AUDIT SUMMARY --------------------");
        Console.WriteLine($"✔ Commits checked: {commitCount}");
        Console.WriteLine($"✔ Trees checked:   {treeCount}");
        Console.WriteLine($"✔ Blobs checked:   {blobCount}");
        Console.WriteLine($"✔ Chunks checked:  {chunkCount}");
        Console.WriteLine($"❌ Invalid signatures: {invalidSignatures}");
        Console.WriteLine($"❌ Missing objects:    {missingObjects}");
        Console.WriteLine("-------------------------------------------------------");

        if (invalidSignatures == 0 && missingObjects == 0)
        {
            Console.WriteLine("\n✅ Audit Result: REPOSITORY INTEGRITY VERIFIED");
        }
        else
        {
            Console.WriteLine("\n⚠️ Audit Result: REPOSITORY COMPROMISED OR CORRUPTED");
        }
    }

    private static bool IsBinaryData(byte[] data)
    {
        if (data == null || data.Length == 0) return false;

        // Quick JSON detection: if it starts with '{', it's probably JSON text
        if (data.Length > 0 && data[0] == '{') return false;

        // Check for UTF-8 BOM (text)
        if (data.Length >= 3 && data[0] == 0xEF && data[1] == 0xBB && data[2] == 0xBF)
            return false;

        // Check for common binary file signatures
        if (data.Length >= 2)
        {
            // PE executable (Windows .exe/.dll)
            if (data[0] == 0x4D && data[1] == 0x5A) return true; // "MZ" header

            // ELF executable (Linux)
            if (data.Length >= 4 && data[0] == 0x7F && data[1] == 0x45 && data[2] == 0x4C && data[3] == 0x46) return true;

            // Other binary formats
            if (data[0] == 0xFF && data[1] == 0xD8) return true; // JPEG
            if (data[0] == 0x89 && data[1] == 0x50) return true; // PNG
            if (data[0] == 0x50 && data[1] == 0x4B) return true; // ZIP/Office docs
        }

        // Heuristic: if more than 20% of bytes are non-printable, it's likely binary
        int sampleSize = Math.Min(256, data.Length);
        int nonPrintableCount = 0;

        for (int i = 0; i < sampleSize; i++)
        {
            byte b = data[i];
            if (b < 32 && b != 9 && b != 10 && b != 13) // Not tab, LF, or CR
            {
                nonPrintableCount++;
            }
            else if (b > 126)
            {
                nonPrintableCount++;
            }
        }

        return (double)nonPrintableCount / sampleSize > 0.20;
    }

    /// <summary>
    /// Helper method to enqueue child objects from a parsed object's content
    /// </summary>
    private static void EnqueueChildren(string content, Queue<string> queue)
    {
        var type = Hash.GetObjectType(content);

        if (type == "commit")
        {
            var c = Commit.FromJson(content);
            if (!string.IsNullOrEmpty(c.ParentHash)) queue.Enqueue(c.ParentHash);
            if (!string.IsNullOrEmpty(c.TreeHash)) queue.Enqueue(c.TreeHash);
        }
        else if (type == "tree")
        {
            var t = Tree.FromJson(content);
            foreach (var e in t.Entries)
                if (!string.IsNullOrEmpty(e.Hash)) queue.Enqueue(e.Hash);
        }
        else if (content.Contains("ChunkHashes") && content.Contains("TotalSize"))
        {
            var ptr = LargeFilePointer.FromJson(content);
            foreach (var ch in ptr.ChunkHashes) queue.Enqueue(ch);
        }
    }

    /// <summary>
    /// Gets the set of object hashes that exist on the remote by checking remote storage.
    /// This is more efficient than downloading everything to check what exists.
    /// </summary>
    public class FlowIgnore
    {
        private readonly List<(Regex Pattern, bool Negate)> _rules = new();

        public static FlowIgnore Load(string repoRoot)
        {
            var ignoreFile = Path.Combine(repoRoot, ".flowignore");

            var ig = new FlowIgnore();
            if (!File.Exists(ignoreFile))
                return ig;

            foreach (var line in File.ReadAllLines(ignoreFile))
            {
                var trimmed = line.Trim();

                // Skip empty or comment
                if (string.IsNullOrWhiteSpace(trimmed) || trimmed.StartsWith("#"))
                    continue;

                bool negate = trimmed.StartsWith("!");
                if (negate)
                    trimmed = trimmed.Substring(1).TrimStart();

                var regex = ConvertPatternToRegex(trimmed);
                ig._rules.Add((regex, negate));
            }

            return ig;
        }

        public bool IsIgnored(string relPath)
        {
            bool ignored = false;

            foreach (var (pattern, negate) in _rules)
            {
                if (pattern.IsMatch(relPath))
                {
                    ignored = !negate;
                }
            }

            return ignored;
        }

        private static Regex ConvertPatternToRegex(string pattern)
        {
            // Convert Git-style ignore patterns to regex
            pattern = pattern.Replace(@"\", "/");

            bool endsWithSlash = pattern.EndsWith("/");

            string regex = Regex.Escape(pattern);

            // Replace common glob patterns
            regex = regex.Replace(@"\*\*", ".*");
            regex = regex.Replace(@"\*", "[^/]*");
            regex = regex.Replace(@"\?", ".");

            if (endsWithSlash)
            {
                // Directory match
                regex = "^" + regex.TrimEnd('/') + "(/.*)?$";
            }
            else
            {
                regex = "^" + regex + "$";
            }

            return new Regex(regex, RegexOptions.IgnoreCase | RegexOptions.Compiled);
        }
    }
    /// <summary>
    /// Traverses the object graph starting from startHash using the provided store and
    /// returns all reachable object hashes (commit, tree, blob, chunk hashes).
    /// </summary>
    /// <summary>
    /// Robust traversal of the object graph starting from startHash using the provided store.
    /// Tries to parse each textual object as: Commit -> Tree -> LargeFilePointer (LFS pointer).
    /// Adds binary blobs/chunks to the set (they have no children).
    /// Returns a HashSet of all reachable object hashes (commit, tree, blobs, chunk hashes).
    /// </summary>
    private static HashSet<string> GetObjectHistorySet(string? startHash, CodeFlow.Storage.ContentAddressableStore store)
    {
        var historySet = new HashSet<string>(StringComparer.Ordinal);

        if (string.IsNullOrEmpty(startHash))
            return historySet;

        // Quick existence check (defensive - some stores may not implement HasObject reliably)
        try
        {
            if (!store.HasObject(startHash))
            {
                Console.WriteLine($"[Debug] Start hash {startHash.Substring(0, 12)} not present in store according to HasObject().");
                // don't return immediately — we'll still try to queue it so missing object will be noticed upstream
            }
        }
        catch
        {
            // Some implementations might throw; ignore and continue
        }

        var q = new Queue<string>();
        q.Enqueue(startHash);
        historySet.Add(startHash);

        while (q.Any())
        {
            var hash = q.Dequeue();

            // Get raw bytes for the object
            byte[]? raw = store.GetRawObject(hash);
            if (raw == null)
            {
                // Missing locally — we'll still keep the hash so it will be uploaded if found elsewhere.
                Console.WriteLine($"[Debug] Local object {hash.Substring(0, 12)} missing from store (GetRawObject returned null).");
                continue;
            }

            // If bytes look binary -> no children
            if (IsBinaryData(raw))
            {
                // binary blob or chunk: already in historySet; nothing to enqueue
                continue;
            }

            // Try to decode as UTF-8 text
            string content;
            try
            {
                content = Encoding.UTF8.GetString(raw);
            }
            catch
            {
                // can't decode -> treat as opaque blob
                continue;
            }

            // 1) Try parse as Commit
            bool parsed = false;
            try
            {
                var c = CodeFlow.Core.Commit.FromJson(content);
                // If we get a valid commit object, enqueue parent/tree if present
                if (!string.IsNullOrEmpty(c.ParentHash) && historySet.Add(c.ParentHash))
                {
                    q.Enqueue(c.ParentHash);
                }
                if (!string.IsNullOrEmpty(c.TreeHash) && historySet.Add(c.TreeHash))
                {
                    q.Enqueue(c.TreeHash);
                }
                parsed = true;
                continue; // success -> done with this object
            }
            catch
            {
                // not a commit (or malformed) -> fall through
            }

            // 2) Try parse as Tree
            try
            {
                var t = CodeFlow.Storage.Tree.FromJson(content);
                if (t?.Entries != null)
                {
                    foreach (var e in t.Entries)
                    {
                        if (string.IsNullOrEmpty(e.Hash)) continue;
                        if (historySet.Add(e.Hash))
                        {
                            q.Enqueue(e.Hash);
                        }
                    }
                }
                parsed = true;
                continue;
            }
            catch
            {
                // not a tree -> fall through
            }

            // 3) Try parse as LargeFilePointer (LFS-style pointer)
            try
            {
                var ptr = CodeFlow.Storage.LargeFilePointer.FromJson(content);
                if (ptr?.ChunkHashes != null)
                {
                    foreach (var ch in ptr.ChunkHashes)
                    {
                        if (string.IsNullOrEmpty(ch)) continue;
                        if (historySet.Add(ch))
                        {
                            q.Enqueue(ch);
                        }
                    }
                }
                parsed = true;
                continue;
            }
            catch
            {
                // not an LFS pointer -> fall through
            }

            // If we reach here the content was textual but didn't parse as any known object.
            // No children expected.
            if (!parsed)
            {
                // optional debug:
                // Console.WriteLine($"[Debug] Text object {hash.Substring(0,12)} parsed as unknown textual type.");
            }
        }

        return historySet;
    }

    static void PrintLocalObjectsSummary(string repoRoot)
    {
        var objectsDir = Path.Combine(repoRoot, ".codeflow", "objects");
        if (!Directory.Exists(objectsDir))
        {
            Console.WriteLine("No .codeflow/objects directory found.");
            return;
        }

        var files = Directory.EnumerateFiles(objectsDir, "*", SearchOption.AllDirectories).ToList();
        Console.WriteLine($"Local object files: {files.Count}");
        foreach (var f in files.Take(20))
        {
            var rel = Path.GetRelativePath(objectsDir, f).Replace('\\', '/');
            Console.WriteLine($" - {rel}");
        }
    }

    static void DumpCommitAndTree(string commitHash)
    {
        var store = new CodeFlow.Storage.ContentAddressableStore(".codeflow/objects");
        var commitJson = store.GetObject(commitHash);
        if (commitJson == null)
        {
            Console.WriteLine($"Commit {commitHash} not found locally.");
            return;
        }

        Console.WriteLine("=== Commit JSON ===");
        Console.WriteLine(commitJson);
        try
        {
            var commit = CodeFlow.Core.Commit.FromJson(commitJson);
            Console.WriteLine($"Commit.TreeHash = {commit.TreeHash ?? "<null-or-empty>"}");

            if (string.IsNullOrEmpty(commit.TreeHash))
            {
                Console.WriteLine("Commit has no TreeHash — bug in commit creation!");
                return;
            }

            var treeJson = store.GetObject(commit.TreeHash);
            if (treeJson == null)
            {
                Console.WriteLine($"Tree {commit.TreeHash} NOT found locally.");
                return;
            }

            Console.WriteLine("=== Tree JSON ===");
            Console.WriteLine(treeJson);

            var tree = CodeFlow.Storage.Tree.FromJson(treeJson);
            Console.WriteLine($"Tree entries: {tree.Entries.Count}");
            foreach (var e in tree.Entries)
            {
                var blobBytes = store.GetRawObject(e.Hash);
                Console.WriteLine($" - {e.Path} -> {e.Hash} ({e.Type}) Exists locally: {(blobBytes != null)} Size: {(blobBytes?.Length ?? 0)}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error parsing commit/tree: {ex.Message}");
        }
    }


